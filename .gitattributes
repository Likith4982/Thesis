# Auto-detect text files and normalize line endings
* text=auto

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.csv text

# Notebooks as text (for diffing)
*.ipynb text

